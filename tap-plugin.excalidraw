    {
      "id": "fHplyI9wTjWSFGVH7fGng",
      "type": "text",
      "x": 4308.322723727188,
      "y": 4597.893655553983,
      "width": 345.80157470703125,
      "height": 35,
      "angle": 0,
      "strokeColor": "#1e1e1e",
