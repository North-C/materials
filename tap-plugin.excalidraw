      "seed": 350788971,
      "version": 184,
      "versionNonce": 330315851,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1746864167663,
      "link": null,
      "locked": false,
      "text": "CPU 和 内存在NUMA上的对应关系，通过 distance 远近关系来作区分。",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CPU 和 内存在NUMA上的对应关系，通过 distance 远近关系来作区分。",
      "autoResize": true,
      "lineHeight": 1.25
    }
